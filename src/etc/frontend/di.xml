<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="MageObsidian\Customer\ViewModel\AccountNav">
        <arguments>
            <argument name="links" xsi:type="array">
                <item name="dashboard" xsi:type="array">
                    <item name="route" xsi:type="string">customer/account</item>
                    <item name="match" xsi:type="string">customer_account_index</item>
                    <item name="label" xsi:type="string" translate="true">Account Dashboard</item>
                    <item name="sortOrder" xsi:type="string">10</item>
                </item>
                <item name="orders" xsi:type="array">
                    <item name="route" xsi:type="string">sales/order/history</item>
                    <item name="match" xsi:type="string">sales_order</item>
                    <item name="label" xsi:type="string" translate="true">My Orders</item>
                    <item name="sortOrder" xsi:type="string">20</item>
                </item>
                <item name="address" xsi:type="array">
                    <item name="route" xsi:type="string">customer/address</item>
                    <item name="match" xsi:type="string">customer_address</item>
                    <item name="label" xsi:type="string" translate="true">Address Book</item>
                    <item name="sortOrder" xsi:type="string">30</item>
                </item>
                <item name="edit" xsi:type="array">
                    <item name="route" xsi:type="string">customer/account/edit</item>
                    <item name="match" xsi:type="string">customer_account_edit</item>
                    <item name="label" xsi:type="string" translate="true">Account Information</item>
                    <item name="sortOrder" xsi:type="string">40</item>
                </item>
                <item name="newsletter" xsi:type="array">
                    <item name="route" xsi:type="string">newsletter/manage</item>
                    <item name="match" xsi:type="string">newsletter_manage</item>
                    <item name="label" xsi:type="string" translate="true">Newsletter Subscriptions</item>
                    <item name="sortOrder" xsi:type="string">50</item>
                </item>
            </argument>
        </arguments>
    </type>
</config>
