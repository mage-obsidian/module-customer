<?xml version="1.0"?>
<!--
  Reset-password page structure — reached from the emailed reset link (token in
  the URL), so the block is non-cacheable. Reuses Magento\Customer\Block\Account\
  Resetpassword as a data source (the reset token). Native POST to
  customer/account/resetPasswordPost; reset-enhancer.ts adds inline match/length
  validation only.
-->
<page layout="1column" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <meta name="robots" content="NOINDEX,NOFOLLOW"/>
        <!-- Re-declare the title the suppressed core <head> would have set. -->
        <title>Set a New Password</title>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="MageObsidian\ModernFrontend\Block\Template" name="obsidian.customer.createpassword"
                   template="Magento_Customer::form/resetpassword.twig" cacheable="false">
                <!-- Name MUST be `resetPassword`: the core CreatePassword controller
                     looks the block up by that name to seed the token/customer id. -->
                <block class="Magento\Customer\Block\Account\Resetpassword" name="resetPassword" as="form_data"/>
            </block>
        </referenceContainer>
    </body>
</page>
