<?xml version="1.0"?>
<!--
  Forgot-password page structure (see customer_account_login.xml for why the
  core layout is re-declared). Reuses Magento\Customer\Block\Account\Forgotpassword
  as a data source. Native POST to customer/account/forgotPasswordPost (which
  sends the reset email); forgot-enhancer.ts adds inline email validation only.
-->
<page layout="1column" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <meta name="robots" content="NOINDEX,NOFOLLOW"/>
        <!-- Re-declare the title the suppressed core <head> would have set. -->
        <title>Forgot Your Password?</title>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="MageObsidian\ModernFrontend\Block\Template" name="obsidian.customer.forgotpassword"
                   template="Magento_Customer::form/forgotpassword.twig">
                <!-- Name MUST be `forgotPassword`: the core ForgotPassword controller
                     looks the block up by that name to seed the persisted email. -->
                <block class="Magento\Customer\Block\Account\Forgotpassword" name="forgotPassword" as="form_data"/>
            </block>
        </referenceContainer>
    </body>
</page>
