<?xml version="1.0"?>
<!--
  Newsletter subscriptions. Pulls in the account shell, then renders our Twig
  over the core Customer\Newsletter block (kept as data source for the current
  subscription state and the save URL). The controller sets the title and the
  block is name-looked-up as `customer_newsletter`. cacheable="false".
-->
<page layout="1column" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceBlock name="account.shell">
            <block class="MageObsidian\ModernFrontend\Block\Template" name="account.newsletter"
                   as="account_content" template="Magento_Customer::account/newsletter.twig" cacheable="false">
                <block class="Magento\Customer\Block\Newsletter" name="customer_newsletter" as="newsletter"/>
            </block>
        </referenceBlock>
    </body>
</page>
